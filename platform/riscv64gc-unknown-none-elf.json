{
  "llvm-target": "riscv64gc-unknown-none-elf",
  "data-layout": "e-m:e-p:64:64-i64:64-i128:128-n32:64-S128",
  "arch": "riscv64",
  "target-endian": "little",
  "target-pointer-width": 64,
  "os": "none",
  "executables": true,
  "linker": "rust-lld",
  "panic-strategy": "abort",
  "disable-redzone": true,
  "features": "+m,+a,+f,+d,+c",
  "max-atomic-width": 64
}
